# Source store (read/export + theme pull)
SOURCE_SHOPIFY_STORE_DOMAIN=quickclipsfloral.com
SOURCE_SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_source_xxx
SOURCE_SHOPIFY_API_VERSION=2025-10
SOURCE_THEME_ID=

# Target store (deploy/sync destination)
TARGET_SHOPIFY_STORE_DOMAIN=target-store.myshopify.com
TARGET_SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_target_xxx
TARGET_SHOPIFY_API_VERSION=2025-10

# Backwards-compatible aliases used by catalog_sync when TARGET_* is not set
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-10

DRY_RUN=true
ENABLE_DIRECT_UPLOAD=true
CDN_BASE_URL=
ALLOW_DELETES=false
LOG_LEVEL=INFO
